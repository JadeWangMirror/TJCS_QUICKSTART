//////////////////////////////////////////////////////////////////////
// 模块名:  mem
// 文件名:  mem.v
// 描述:    访存阶段 (Memory Stage) — OpenMIPS 五级流水线的第四级
//
//          模块功能概述:
//            本模块实现 MIPS 处理器的访存(MEM)阶段,负责以下核心功能:
//
//            1. 加载指令执行 (LB/LBU/LH/LHU/LW/LWL/LWR/LL):
//               - 从数据存储器(data RAM)读取数据
//               - 支持字节(byte)、半字(halfword)、字(word)读取
//               - 支持带符号扩展(LB/LH)和无符号扩展(LBU/LHU)
//               - LWL/LWR 支持非对齐(unaligned)访存
//               - LL(Load-Linked)用于原子操作序列
//
//            2. 存储指令执行 (SB/SH/SW/SWL/SWR/SC):
//               - 向数据存储器写入数据
//               - 根据地址低2位生成 mem_sel_o 字节选通信号
//               - SC(Store-Conditional)需要检查 LLbit 状态:
//                 LLbit==1 时执行写入并返回1(成功)
//                 LLbit==0 时跳过写入并返回0(失败)
//
//            3. LL/SC 原子操作支持:
//               - LL 指令: 读取数据并置 LLbit=1
//               - SC 指令: 仅当 LLbit==1 时才写入存储器
//               - LLbit 需要考虑 WB 阶段可能同时写 LLbit 的数据相关
//
//            4. 异常处理判断:
//               - 根据 excepttype_i 的异常标志位判断各类异常
//               - 支持中断(interrupt)、系统调用(syscall)、无效指令(invalid inst)
//               - 支持自陷(trap)、溢出(ov)、ERET 返回指令
//               - 异常优先级: 中断 > syscall > 无效指令 > trap > 溢出 > ERET
//
//            5. CP0 寄存器数据旁路:
//               - 接收来自执行阶段的 CP0 写信息
//               - 检查 WB 阶段是否正在写 CP0(数据相关旁路)
//               - 获取 CP0 Status/Cause/EPC 的最新值用于异常判断
//
//            数据通路:
//              输入(来自 EX/MEM):
//                mem_addr_i     -> 访存地址(来自 ALU 结果)
//                reg2_i         -> 待写入数据(store 指令的 rt 寄存器)
//                aluop_i        -> 访存操作类型编码
//              输出(到 data RAM):
//                mem_addr_o     -> 数据总线地址
//                mem_data_o     -> 写入数据(经过字节重组)
//                mem_sel_o      -> 字节选通信号(4bit,对应4字节)
//                mem_ce_o       -> 芯片使能信号
//                mem_we_o       -> 写使能信号(异常时强制禁用)
//              输出(到 MEM/WB 流水线寄存器):
//                wd_o           -> 目的寄存器地址
//                wreg_o         -> 寄存器写使能
//                wdata_o        -> 写回数据(load结果或store返回值)
//                hi_o/lo_o      -> HI/LO 寄存器值(直通)
//                whilo_o        -> HI/LO 写使能(直通)
//                LLbit_we_o     -> LLbit 写使能
//                LLbit_value_o  -> LLbit 写入值
//                cp0_reg_*_o    -> CP0 写信息(直通)
//                excepttype_o   -> 异常类型编码(32bit)
//                cp0_epc_o      -> EPC 值(传递)
//                is_in_delayslot_o -> 延迟槽标志(直通)
//////////////////////////////////////////////////////////////////////

`include "defines.v"

module mem(

	// 全局复位信号, 高电平有效
	input wire										rst,

	// ===== 来自执行(EX)阶段的流水线寄存器信息 =====
	// 目的寄存器编号, 用于写回
	input wire[`RegAddrBus]       wd_i,
	// 寄存器写使能信号
	input wire                    wreg_i,
	// 写回数据(算术/逻辑运算结果)
	input wire[`RegBus]					  wdata_i,
	// HI 寄存器值(乘除法/MFHI)
	input wire[`RegBus]           hi_i,
	// LO 寄存器值(乘除法/MFLO)
	input wire[`RegBus]           lo_i,
	// HI/LO 寄存器写使能
	input wire                    whilo_i,

	// ALU 操作类型编码, 用于区分具体访存指令(LB/LH/LW/SB/SH/SW 等)
  input wire[`AluOpBus]        aluop_i,
	// 访存地址(来自 ALU 计算结果), 字节地址
	input wire[`RegBus]          mem_addr_i,
	// 第二个源操作数(rt 寄存器值), store 指令时作为待写入数据
	input wire[`RegBus]          reg2_i,

	// ===== 来自 data RAM (Wishbone 总线) 的读数据 =====
	// 从数据存储器读回的 32bit 数据字
	input wire[`RegBus]          mem_data_i,

	// ===== LLbit (Load-Linked bit) 相关信号 =====
	// LLbit 寄存器的当前值(来自 LLbit_reg 模块)
	input wire                  LLbit_i,
	// WB 阶段是否正在写 LLbit(用于数据相关旁路判断)
	// 如果 WB 阶段也在写 LLbit, 则需要使用 WB 阶段的新值
	input wire                  wb_LLbit_we_i,
	// WB 阶段写入 LLbit 的值(旁路数据)
	input wire                  wb_LLbit_value_i,

	// ===== CP0 协处理器写信号(来自 EX 阶段) =====
	// CP0 寄存器写使能(MTC0 指令)
	input wire                   cp0_reg_we_i,
	// CP0 寄存器写地址(5bit, 对应 0~31 号 CP0 寄存器)
	input wire[4:0]              cp0_reg_write_addr_i,
	// CP0 寄存器写入数据
	input wire[`RegBus]          cp0_reg_data_i,

	// ===== 异常相关信号(来自 EX 阶段) =====
	// 异常类型标志位(32bit, 每一位代表一种异常条件)
	// bit[8]:  syscall    (系统调用)
	// bit[9]:  无效指令   (inst_invalid)
	// bit[10]: trap       (自陷)
	// bit[11]: ov         (溢出)
	// bit[12]: ERET       (异常返回)
	input wire[31:0]             excepttype_i,
	// 当前指令是否在延迟槽中(用于异常返回地址计算)
	input wire                   is_in_delayslot_i,
	// 当前指令的 PC 地址(异常时保存到 EPC)
	input wire[`RegBus]          current_inst_address_i,

	// ===== CP0 寄存器值(来自 CP0 模块) =====
	// 注意: 这些值可能不是最新的, 需要检查 WB 阶段是否正在写 CP0
	// CP0 Status 寄存器: 中断使能、运行模式(用户/内核态)等
	input wire[`RegBus]          cp0_status_i,
	// CP0 Cause 寄存器: 中断源 IP[15:10]、异常码 ExcCode[6:2] 等
	input wire[`RegBus]          cp0_cause_i,
	// CP0 EPC 寄存器: 异常返回地址
	input wire[`RegBus]          cp0_epc_i,

	// ===== WB 阶段 CP0 写信息(用于数据相关旁路) =====
	// 如果 WB 阶段正在写 CP0, MEM 阶段需要使用 WB 的新值
  input wire                    wb_cp0_reg_we,
	// WB 阶段写的 CP0 寄存器地址
	input wire[4:0]               wb_cp0_reg_write_addr,
	// WB 阶段写的 CP0 寄存器数据
	input wire[`RegBus]           wb_cp0_reg_data,

	// ===== 输出到 WB(回写)阶段的流水线寄存器 =====
	// 目的寄存器编号(直通 EX 阶段)
	output reg[`RegAddrBus]      wd_o,
	// 寄存器写使能(直通)
	output reg                   wreg_o,
	// 写回数据(load 结果为从存储器读取的数据,其他指令直通 EX 结果)
	output reg[`RegBus]					 wdata_o,
	// HI 寄存器值(直通)
	output reg[`RegBus]          hi_o,
	// LO 寄存器值(直通)
	output reg[`RegBus]          lo_o,
	// HI/LO 写使能(直通)
	output reg                   whilo_o,

	// LLbit 写使能(LL 指令置1, SC 指令置0)
	output reg                   LLbit_we_o,
	// LLbit 写入值(LL 写1, SC 写0)
	output reg                   LLbit_value_o,

	// CP0 写使能(直通 EX 阶段)
	output reg                   cp0_reg_we_o,
	// CP0 写地址(直通)
	output reg[4:0]              cp0_reg_write_addr_o,
	// CP0 写数据(直通)
	output reg[`RegBus]          cp0_reg_data_o,

	// ===== 输出到 data RAM (Wishbone 总线接口) =====
	// 数据存储器地址总线
	output reg[`RegBus]          mem_addr_o,
	// 数据存储器写使能(异常时由 assign 强制为0)
	output wire									 mem_we_o,
	// 字节选通信号(4bit, mem_sel_o[i] 对应字节 i)
	// 4'b1111: 写全部4字节; 4'b0001: 仅写最低字节; 等
	output reg[3:0]              mem_sel_o,
	// 写入数据存储器的数据(经过字节对齐/复制处理)
	output reg[`RegBus]          mem_data_o,
	// 数据存储器芯片使能(拉高时访问 RAM)
	output reg                   mem_ce_o,

	// ===== 异常输出 =====
	// 异常类型编码(32bit):
	//   32'h00000001: 中断(interrupt)
	//   32'h00000008: 系统调用(syscall)
	//   32'h0000000a: 无效指令(inst_invalid)
	//   32'h0000000d: 自陷(trap)
	//   32'h0000000c: 溢出(ov)
	//   32'h0000000e: 异常返回(ERET)
	output reg[31:0]             excepttype_o,
	// EPC 值(传递给 CP0 和后续阶段)
	output wire[`RegBus]          cp0_epc_o,
	// 延迟槽标志(直通)
	output wire                  is_in_delayslot_o,

	// 当前指令地址(直通, 供后续阶段使用)
	output wire[`RegBus]         current_inst_address_o

);

  // ===== 内部寄存器/线网声明 =====
	// LLbit 的最新值(经过 WB 旁路判断后的值)
  reg LLbit;
	// 32bit 零值常量, 用于填充/拼接
	wire[`RegBus] zero32;
	// CP0 Status 寄存器的最新值(经过 WB 旁路)
	reg[`RegBus]          cp0_status;
	// CP0 Cause 寄存器的最新值(经过 WB 旁路)
	reg[`RegBus]          cp0_cause;
	// CP0 EPC 寄存器的最新值(经过 WB 旁路)
	reg[`RegBus]          cp0_epc;
	// 内部 mem 写使能(组合逻辑产生, 防止异常时误写入)
	reg                   mem_we;

	// ===== 组合逻辑赋值 =====
	// mem_we_o: 写使能仅在非异常时有效(异常时强制为0, 防止错误写入)
	assign mem_we_o = mem_we & (~(|excepttype_o));
	// zero32 恒为 0
	assign zero32 = `ZeroWord;

	// 以下信号直通(不经过组合逻辑修改):
	// 延迟槽标志直通输出
	assign is_in_delayslot_o = is_in_delayslot_i;
	// 当前指令地址直通输出
	assign current_inst_address_o = current_inst_address_i;
	// EPC 输出(使用经过旁路处理的最新 cp0_epc)
	assign cp0_epc_o = cp0_epc;

  // ===================================================================
	// always 块: 获取最新的 LLbit 值
	// 功能: LLbit 是一个 1bit 标志, 用于 LL/SC 原子操作序列
	//       - LL(Load-Linked) 指令执行时置 LLbit=1
	//       - SC(Store-Conditional) 仅在 LLbit==1 时才执行写入
	//       - 任何对同一地址的写操作都应使 LLbit 清零
	//
	// 数据旁路: 如果 WB 阶段正在写 LLbit (wb_LLbit_we_i==1),
	//           则使用 WB 阶段的新值, 否则使用 LLbit_i 的当前值
	//           这解决了 MEM 和 WB 阶段之间的 LLbit 数据相关
	// ===================================================================
	always @ (*) begin
		if(rst == `RstEnable) begin
			// 复位: LLbit 清零
			LLbit <= 1'b0;
		end else begin
			// 数据旁路判断: WB 阶段写 LLbit 时使用新值
			if(wb_LLbit_we_i == 1'b1) begin
				LLbit <= wb_LLbit_value_i;
			end else begin
				// 否则使用当前 LLbit 值
				LLbit <= LLbit_i;
			end
		end
	end
	
	// ===================================================================
	// always 块: 访存操作主控制逻辑
	// 功能: 这是 MEM 阶段的核心组合逻辑, 根据 aluop_i (ALU 操作码) 来区分
	//       不同的访存指令并产生相应的控制信号和数据通路
	//
	// 复位状态: 所有输出清零/禁用
	// 正常状态:
	//   1. 默认值: 先赋默认值(直通 EX 阶段结果, 访存信号为禁用状态)
	//   2. case 分支: 根据 aluop_i 跳转到对应指令的处理
	//
	// 每个 case 分支对应一种访存指令:
	//   Load 类: 设置 mem_ce_o=1 (使能 RAM), 根据地址偏移选择对应字节
	//   Store 类: 设置 mem_ce_o=1 和 mem_we=1 (使能写), 复制 rt 值到各字节
	// ===================================================================
	always @ (*) begin
		if(rst == `RstEnable) begin
			// 复位: 所有输出清零/禁用
			wd_o <= `NOPRegAddr;          // 目的寄存器 = NOP (不写)
			wreg_o <= `WriteDisable;       // 禁止寄存器写
		  wdata_o <= `ZeroWord;          // 写回数据 = 0
		  hi_o <= `ZeroWord;              // HI = 0
		  lo_o <= `ZeroWord;              // LO = 0
		  whilo_o <= `WriteDisable;       // 禁止 HI/LO 写
		  mem_addr_o <= `ZeroWord;        // 访存地址 = 0
		  mem_we <= `WriteDisable;        // 禁止存储器写
		  mem_sel_o <= 4'b0000;           // 不选通任何字节
		  mem_data_o <= `ZeroWord;        // 写数据 = 0
		  mem_ce_o <= `ChipDisable;       // 禁止 RAM 芯片使能
		  LLbit_we_o <= 1'b0;             // 不写 LLbit
		  LLbit_value_o <= 1'b0;          // LLbit 写值 = 0
		  cp0_reg_we_o <= `WriteDisable;  // 不写 CP0
		  cp0_reg_write_addr_o <= 5'b00000; // CP0 地址 = 0
		  cp0_reg_data_o <= `ZeroWord;    // CP0 数据 = 0
		end else begin
		  // ===== 默认赋值(直通 EX 阶段结果) =====
		  wd_o <= wd_i;                    // 目的寄存器直通
			wreg_o <= wreg_i;                // 寄存器写使能直通
			wdata_o <= wdata_i;              // 写回数据直通(load 指令会覆盖)
			hi_o <= hi_i;                    // HI 直通
			lo_o <= lo_i;                    // LO 直通
			whilo_o <= whilo_i;              // HI/LO 写使能直通
			// ===== 默认赋值(访存信号默认为禁用) =====
			mem_we <= `WriteDisable;         // 默认不写存储器
			mem_addr_o <= `ZeroWord;         // 默认地址 = 0
			mem_sel_o <= 4'b1111;            // 默认全字节选通(LW/SW 等使用)
			mem_ce_o <= `ChipDisable;        // 默认不使能 RAM
		  LLbit_we_o <= 1'b0;              // 默认不写 LLbit
		  LLbit_value_o <= 1'b0;           // 默认 LLbit 值 = 0
		  // ===== CP0 信号直通 =====
		  cp0_reg_we_o <= cp0_reg_we_i;     // CP0 写使能直通
		  cp0_reg_write_addr_o <= cp0_reg_write_addr_i; // CP0 地址直通
		  cp0_reg_data_o <= cp0_reg_data_i; // CP0 数据直通		 		  	
		  // ===== 根据 aluop_i 判断访存指令类型 =====
			case (aluop_i)
				// ---------------------------------------------------------------
				// LB (Load Byte): 加载字节, 带符号扩展
				// 从 data RAM 读取指定字节, 将该字节的 bit[7] 符号扩展到高 24 位
				// 根据低 2 位地址选择对应字节通道:
				//   mem_addr_i[1:0]=00 -> 读最高字节 mem_data_i[31:24]
				//   mem_addr_i[1:0]=01 -> 读次高字节 mem_data_i[23:16]
				//   mem_addr_i[1:0]=10 -> 读次低字节 mem_data_i[15:8]
				//   mem_addr_i[1:0]=11 -> 读最低字节 mem_data_i[7:0]
				// mem_sel_o 选通对应字节(bit=1 表示使能该字节)
				// ---------------------------------------------------------------
				`EXE_LB_OP:		begin
					mem_addr_o <= mem_addr_i;               // 输出地址
					mem_we <= `WriteDisable;                 // 读操作
					mem_ce_o <= `ChipEnable;                 // 使能 RAM
					case (mem_addr_i[1:0])                   // 根据低2位地址选择字节
						2'b00:	begin                          // 地址对齐到 4 字节边界 + 0
							wdata_o <= {{24{mem_data_i[31]}},mem_data_i[31:24]}; // 取 [31:24], 符号扩展
							mem_sel_o <= 4'b1000;                // 仅选通字节3(最高字节)
						end
						2'b01:	begin                          // 地址对齐 + 1
							wdata_o <= {{24{mem_data_i[23]}},mem_data_i[23:16]}; // 取 [23:16], 符号扩展
							mem_sel_o <= 4'b0100;                // 仅选通字节2
						end
						2'b10:	begin                          // 地址对齐 + 2
							wdata_o <= {{24{mem_data_i[15]}},mem_data_i[15:8]}; // 取 [15:8], 符号扩展
							mem_sel_o <= 4'b0010;                // 仅选通字节1
						end
						2'b11:	begin                          // 地址对齐 + 3
							wdata_o <= {{24{mem_data_i[7]}},mem_data_i[7:0]}; // 取 [7:0], 符号扩展
							mem_sel_o <= 4'b0001;                // 仅选通字节0(最低字节)
						end
						default:	begin
							wdata_o <= `ZeroWord;
						end
					endcase
				end
				// ---------------------------------------------------------------
				// LBU (Load Byte Unsigned): 加载字节, 无符号扩展
				// 与 LB 相同, 但高 24 位填 0 而不是符号扩展
				// ---------------------------------------------------------------
				`EXE_LBU_OP:		begin
					mem_addr_o <= mem_addr_i;               // 输出地址
					mem_we <= `WriteDisable;                 // 读操作
					mem_ce_o <= `ChipEnable;                 // 使能 RAM
					case (mem_addr_i[1:0])                   // 根据低2位地址选择字节
						2'b00:	begin                          // 地址对齐 + 0
							wdata_o <= {{24{1'b0}},mem_data_i[31:24]}; // 取 [31:24], 高位填0
							mem_sel_o <= 4'b1000;                // 仅选通字节3
						end
						2'b01:	begin                          // 地址对齐 + 1
							wdata_o <= {{24{1'b0}},mem_data_i[23:16]}; // 取 [23:16], 高位填0
							mem_sel_o <= 4'b0100;                // 仅选通字节2
						end
						2'b10:	begin                          // 地址对齐 + 2
							wdata_o <= {{24{1'b0}},mem_data_i[15:8]}; // 取 [15:8], 高位填0
							mem_sel_o <= 4'b0010;                // 仅选通字节1
						end
						2'b11:	begin                          // 地址对齐 + 3
							wdata_o <= {{24{1'b0}},mem_data_i[7:0]}; // 取 [7:0], 高位填0
							mem_sel_o <= 4'b0001;                // 仅选通字节0
						end
						default:	begin
							wdata_o <= `ZeroWord;
						end
					endcase
				end
				// ---------------------------------------------------------------
				// LH (Load Halfword): 加载半字(2字节), 带符号扩展
				// 仅支持半字对齐地址(低1位必须为0, 即 2'b00 或 2'b10)
				//   mem_addr_i[1:0]=00 -> 读高半字 mem_data_i[31:16], 符号扩展
				//   mem_addr_i[1:0]=10 -> 读低半字 mem_data_i[15:0], 符号扩展
				// ---------------------------------------------------------------
				`EXE_LH_OP:		begin
					mem_addr_o <= mem_addr_i;               // 输出地址
					mem_we <= `WriteDisable;                 // 读操作
					mem_ce_o <= `ChipEnable;                 // 使能 RAM
					case (mem_addr_i[1:0])
						2'b00:	begin                          // 半字对齐边界(高半字)
							wdata_o <= {{16{mem_data_i[31]}},mem_data_i[31:16]}; // 取 [31:16], 符号扩展到32位
							mem_sel_o <= 4'b1100;                // 选通字节3,2(高2字节)
						end
						2'b10:	begin                          // 半字对齐边界(低半字)
							wdata_o <= {{16{mem_data_i[15]}},mem_data_i[15:0]}; // 取 [15:0], 符号扩展
							mem_sel_o <= 4'b0011;                // 选通字节1,0(低2字节)
						end
						default:	begin
							wdata_o <= `ZeroWord;
						end
					endcase
				end
				// ---------------------------------------------------------------
				// LHU (Load Halfword Unsigned): 加载半字, 无符号扩展
				// 与 LH 相同, 但高 16 位填 0
				// ---------------------------------------------------------------
				`EXE_LHU_OP:		begin
					mem_addr_o <= mem_addr_i;               // 输出地址
					mem_we <= `WriteDisable;                 // 读操作
					mem_ce_o <= `ChipEnable;                 // 使能 RAM
					case (mem_addr_i[1:0])
						2'b00:	begin                          // 半字对齐(高半字)
							wdata_o <= {{16{1'b0}},mem_data_i[31:16]}; // 取 [31:16], 高位填0
							mem_sel_o <= 4'b1100;                // 选通字节3,2
						end
						2'b10:	begin                          // 半字对齐(低半字)
							wdata_o <= {{16{1'b0}},mem_data_i[15:0]}; // 取 [15:0], 高位填0
							mem_sel_o <= 4'b0011;                // 选通字节1,0
						end
						default:	begin
							wdata_o <= `ZeroWord;
						end
					endcase
				end
				// ---------------------------------------------------------------
				// LW (Load Word): 加载字(4字节)
				// 直接读取整个 32bit 字, 要求地址 4 字节对齐
				// ---------------------------------------------------------------
				`EXE_LW_OP:		begin
					mem_addr_o <= mem_addr_i;               // 输出地址(4字节对齐)
					mem_we <= `WriteDisable;                 // 读操作
					wdata_o <= mem_data_i;                   // 直接取 32bit 数据
					mem_sel_o <= 4'b1111;                    // 选通全部4字节
					mem_ce_o <= `ChipEnable;                 // 使能 RAM
				end
				// ---------------------------------------------------------------
				// LWL (Load Word Left): 非对齐加载(左侧部分)
				// 从对齐的 4 字节边界(mem_addr_i[31:2], 2'b00)读一个完整字
				// 然后根据地址低2位, 将读取数据的高位部分与 reg2_i(原rt值)的低位
				// 部分合并, 实现非对齐字加载
				//   mem_addr_i[1:0]=00: 全部来自 mem_data_i[31:0]
				//   mem_addr_i[1:0]=01: 高3字节来自 mem, 低1字节来自 reg2
				//   mem_addr_i[1:0]=10: 高2字节来自 mem, 低2字节来自 reg2
				//   mem_addr_i[1:0]=11: 高1字节来自 mem, 低3字节来自 reg2
				// LWL 通常与 LWR 成对使用(LWL 在前, LWR 在后)完成非对齐加载
				// ---------------------------------------------------------------
				`EXE_LWL_OP:		begin
					mem_addr_o <= {mem_addr_i[31:2], 2'b00}; // 向下对齐到字边界(低2位清零)
					mem_we <= `WriteDisable;                 // 读操作
					mem_sel_o <= 4'b1111;                    // 全字节选通
					mem_ce_o <= `ChipEnable;                 // 使能 RAM
					case (mem_addr_i[1:0])
						2'b00:	begin                          // 地址正好4字节对齐
							wdata_o <= mem_data_i[31:0];         // 全部来自存储器
						end
						2'b01:	begin                          // 地址偏移 +1
							wdata_o <= {mem_data_i[23:0],reg2_i[7:0]}; // 高3字节来自mem, 低1字节保留rt[7:0]
						end
						2'b10:	begin                          // 地址偏移 +2
							wdata_o <= {mem_data_i[15:0],reg2_i[15:0]}; // 高2字节来自mem, 低2字节保留rt[15:0]
						end
						2'b11:	begin                          // 地址偏移 +3
							wdata_o <= {mem_data_i[7:0],reg2_i[23:0]}; // 高1字节来自mem, 低3字节保留rt[23:0]
						end
						default:	begin
							wdata_o <= `ZeroWord;
						end
					endcase
				end
				// ---------------------------------------------------------------
				// LWR (Load Word Right): 非对齐加载(右侧部分)
				// 与 LWL 对称: 从对齐的 4 字节边界读取, 将读取数据的低位部分
				// 与 reg2_i(原rt值)的高位部分合并
				//   mem_addr_i[1:0]=00: 低1字节来自 mem, 高3字节来自 reg2
				//   mem_addr_i[1:0]=01: 低2字节来自 mem, 高2字节来自 reg2
				//   mem_addr_i[1:0]=10: 低3字节来自 mem, 高1字节来自 reg2
				//   mem_addr_i[1:0]=11: 全部来自 mem
				// LWR 通常在 LWL 之后执行, 两者结合完成非对齐字加载
				// ---------------------------------------------------------------
				`EXE_LWR_OP:		begin
					mem_addr_o <= {mem_addr_i[31:2], 2'b00}; // 向下对齐到字边界
					mem_we <= `WriteDisable;                 // 读操作
					mem_sel_o <= 4'b1111;                    // 全字节选通
					mem_ce_o <= `ChipEnable;                 // 使能 RAM
					case (mem_addr_i[1:0])
						2'b00:	begin                          // 地址偏移 +0
							wdata_o <= {reg2_i[31:8],mem_data_i[31:24]}; // 高3字节保留rt, 低1字节来自mem[31:24]
						end
						2'b01:	begin                          // 地址偏移 +1
							wdata_o <= {reg2_i[31:16],mem_data_i[31:16]}; // 高2字节保留rt, 低2字节来自mem[31:16]
						end
						2'b10:	begin                          // 地址偏移 +2
							wdata_o <= {reg2_i[31:24],mem_data_i[31:8]}; // 高1字节保留rt, 低3字节来自mem[31:8]
						end
						2'b11:	begin                          // 地址偏移 +3
							wdata_o <= mem_data_i;               // 全部来自存储器
						end
						default:	begin
							wdata_o <= `ZeroWord;
						end
					endcase
				end
				// ---------------------------------------------------------------
				// LL (Load-Linked): 链接加载 — 原子操作的第一步
				// 功能: 与 LW 相同(读取32bit字), 同时置 LLbit=1
				//       LLbit 置1表示已建立一个"链接"
				//       后续 SC 指令仅当 LLbit==1 时才执行写入
				// MIPS 架构: LL/SC 配对用于实现原子操作(如原子加法、CAS)
				// ---------------------------------------------------------------
				`EXE_LL_OP:		begin
					mem_addr_o <= mem_addr_i;               // 输出地址
					mem_we <= `WriteDisable;                 // 读操作
					wdata_o <= mem_data_i;                   // 加载32bit数据
		  		LLbit_we_o <= 1'b1;                      // 写 LLbit
		  		LLbit_value_o <= 1'b1;                   // LLbit = 1(建立链接)
		  		mem_sel_o <= 4'b1111;                    // 全字节选通
		  		mem_ce_o <= `ChipEnable;                 // 使能 RAM
				end
				// ---------------------------------------------------------------
				// SB (Store Byte): 存储字节
				// 将 rt 寄存器的低字节 reg2_i[7:0] 复制4份到 mem_data_o 的各字节位置
				// 然后根据低2位地址选通对应的字节通道写入
				// 复制4份的目的是: 无论地址如何, 正确的字节都在对应位置
				// ---------------------------------------------------------------
				`EXE_SB_OP:		begin
					mem_addr_o <= mem_addr_i;               // 输出地址
					mem_we <= `WriteEnable;                  // 写操作
					// 将低字节复制4份: {byte, byte, byte, byte}
					mem_data_o <= {reg2_i[7:0],reg2_i[7:0],reg2_i[7:0],reg2_i[7:0]};
					mem_ce_o <= `ChipEnable;                 // 使能 RAM
					case (mem_addr_i[1:0])                   // 根据低2位地址选通对应字节
						2'b00:	begin                          // 写入字节3(最高字节)
							mem_sel_o <= 4'b1000;
						end
						2'b01:	begin                          // 写入字节2
							mem_sel_o <= 4'b0100;
						end
						2'b10:	begin                          // 写入字节1
							mem_sel_o <= 4'b0010;
						end
						2'b11:	begin                          // 写入字节0(最低字节)
							mem_sel_o <= 4'b0001;
						end
						default:	begin
							mem_sel_o <= 4'b0000;                // 无效地址, 不选通
						end
					endcase
				end
				// ---------------------------------------------------------------
				// SH (Store Halfword): 存储半字(2字节)
				// 将 rt 寄存器的低半字 reg2_i[15:0] 复制2份到 mem_data_o
				// 要求半字对齐地址(低1位为0)
				// ---------------------------------------------------------------
				`EXE_SH_OP:		begin
					mem_addr_o <= mem_addr_i;               // 输出地址
					mem_we <= `WriteEnable;                  // 写操作
					// 将低半字复制2份: {halfword, halfword}
					mem_data_o <= {reg2_i[15:0],reg2_i[15:0]};
					mem_ce_o <= `ChipEnable;                 // 使能 RAM
					case (mem_addr_i[1:0])
						2'b00:	begin                          // 写入高半字(字节3,2)
							mem_sel_o <= 4'b1100;
						end
						2'b10:	begin                          // 写入低半字(字节1,0)
							mem_sel_o <= 4'b0011;
						end
						default:	begin                          // 非半字对齐地址
							mem_sel_o <= 4'b0000;
						end
					endcase
				end
				// ---------------------------------------------------------------
				// SW (Store Word): 存储字(4字节)
				// 直接写入整个 32bit 字, 要求地址 4 字节对齐
				// ---------------------------------------------------------------
				`EXE_SW_OP:		begin
					mem_addr_o <= mem_addr_i;               // 输出地址(4字节对齐)
					mem_we <= `WriteEnable;                  // 写操作
					mem_data_o <= reg2_i;                    // 写入 rt 寄存器值
					mem_sel_o <= 4'b1111;                    // 选通全部4字节
					mem_ce_o <= `ChipEnable;                 // 使能 RAM
				end
				// ---------------------------------------------------------------
				// SWL (Store Word Left): 非对齐存储(左侧部分)
				// 将 rt 寄存器数据写入对齐地址的高位部分
				// 未写入的低位填充 zero32(全0), 依靠 mem_sel_o 选通正确的字节
				//   mem_addr_i[1:0]=00: 写入全部4字节 (reg2_i[31:0])
				//   mem_addr_i[1:0]=01: 写入高3字节 (reg2_i[31:8]), 低1字节不写
				//   mem_addr_i[1:0]=10: 写入高2字节 (reg2_i[31:16]), 低2字节不写
				//   mem_addr_i[1:0]=11: 写入高1字节 (reg2_i[31:24]), 低3字节不写
				// SWL 与 SWR 成对使用完成非对齐存储
				// ---------------------------------------------------------------
				`EXE_SWL_OP:		begin
					mem_addr_o <= {mem_addr_i[31:2], 2'b00};    // 向下对齐到字边界
					mem_we <= `WriteEnable;                     // 写操作
					mem_ce_o <= `ChipEnable;                    // 使能 RAM
					case (mem_addr_i[1:0])
						2'b00:	begin                             // 地址4字节对齐
							mem_sel_o <= 4'b1111;                   // 写全部4字节
							mem_data_o <= reg2_i;                   // 全部写入 rt 值
						end
						2'b01:	begin                             // 地址偏移 +1
							mem_sel_o <= 4'b0111;                   // 写字节3,2,1(高3字节)
							mem_data_o <= {zero32[7:0],reg2_i[31:8]}; // rt[31:8]移到高3字节, 低字节填0
						end
						2'b10:	begin                             // 地址偏移 +2
							mem_sel_o <= 4'b0011;                   // 写字节1,0(低2字节)
							mem_data_o <= {zero32[15:0],reg2_i[31:16]}; // rt[31:16]移到低2字节, 高2字节填0
						end
						2'b11:	begin                             // 地址偏移 +3
							mem_sel_o <= 4'b0001;                   // 仅写字节0(最低字节)
							mem_data_o <= {zero32[23:0],reg2_i[31:24]}; // rt[31:24]移到最低字节, 高3字节填0
						end
						default:	begin
							mem_sel_o <= 4'b0000;                   // 无效地址
						end
					endcase
				end
				// ---------------------------------------------------------------
				// SWR (Store Word Right): 非对齐存储(右侧部分)
				// 与 SWL 对称: 将 rt 寄存器数据写入对齐地址的低位部分
				//   mem_addr_i[1:0]=00: 写入低1字节 (reg2_i[7:0])
				//   mem_addr_i[1:0]=01: 写入低2字节 (reg2_i[15:0])
				//   mem_addr_i[1:0]=10: 写入低3字节 (reg2_i[23:0])
				//   mem_addr_i[1:0]=11: 写入全部4字节 (reg2_i[31:0])
				// ---------------------------------------------------------------
				`EXE_SWR_OP:		begin
					mem_addr_o <= {mem_addr_i[31:2], 2'b00};    // 向下对齐到字边界
					mem_we <= `WriteEnable;                     // 写操作
					mem_ce_o <= `ChipEnable;                    // 使能 RAM
					case (mem_addr_i[1:0])
						2'b00:	begin                             // 地址偏移 +0
							mem_sel_o <= 4'b1000;                   // 仅写字节3(最高字节)
							mem_data_o <= {reg2_i[7:0],zero32[23:0]}; // rt[7:0]移到最高字节, 低3字节填0
						end
						2'b01:	begin                             // 地址偏移 +1
							mem_sel_o <= 4'b1100;                   // 写字节3,2(高2字节)
							mem_data_o <= {reg2_i[15:0],zero32[15:0]}; // rt[15:0]移到高2字节, 低2字节填0
						end
						2'b10:	begin                             // 地址偏移 +2
							mem_sel_o <= 4'b1110;                   // 写字节3,2,1(高3字节)
							mem_data_o <= {reg2_i[23:0],zero32[7:0]}; // rt[23:0]移到高3字节, 最低字节填0
						end
						2'b11:	begin                             // 地址偏移 +3
							mem_sel_o <= 4'b1111;                   // 写全部4字节
							mem_data_o <= reg2_i[31:0];             // 全部写入
						end
						default:	begin
							mem_sel_o <= 4'b0000;                   // 无效地址
						end
					endcase
				end 
				// ---------------------------------------------------------------
				// SC (Store-Conditional): 条件存储 — 原子操作的第二步
				// 功能: 仅当 LLbit==1 时才执行写存储器操作
				//       LLbit==1: 执行写入, 返回 1(成功)到 rt, 同时写 LLbit=0
				//       LLbit==0: 不执行写入, 返回 0(失败)到 rt (mem_ce_o 保持默认0)
				// MIPS 架构语义:
				//   - SC 成功: rt=1, 数据写入存储器, LLbit 清零
				//   - SC 失败: rt=0, 不写存储器, 表示自 LL 以来数据可能已被修改
				// ---------------------------------------------------------------
				`EXE_SC_OP:		begin
					if(LLbit == 1'b1) begin                     // LLbit 置位: 链接仍然有效
						LLbit_we_o <= 1'b1;                       // 写 LLbit
						LLbit_value_o <= 1'b0;                    // LLbit = 0(清除链接)
						mem_addr_o <= mem_addr_i;                  // 输出地址
						mem_we <= `WriteEnable;                    // 写操作
						mem_data_o <= reg2_i;                      // 写入 rt 值
						wdata_o <= 32'b1;                         // 返回 1(SC 成功)
						mem_sel_o <= 4'b1111;                      // 全字节选通
						mem_ce_o <= `ChipEnable;                   // 使能 RAM
					end else begin                              // LLbit==0: 链接已失效
						wdata_o <= 32'b0;                         // 返回 0(SC 失败), 不写存储器
					end
				end				
				default:		begin
          // 非访存指令(算术/逻辑/跳转等): 不做任何额外操作
									// 所有访存信号保持默认的禁用状态
				end
			endcase							
		end    //if (!rst)
	end      //always (访存操作主控制逻辑)

	always @ (*) begin
		if(rst == `RstEnable) begin
			cp0_status <= `ZeroWord;
		end else if((wb_cp0_reg_we == `WriteEnable) && 
								(wb_cp0_reg_write_addr == `CP0_REG_STATUS ))begin
			cp0_status <= wb_cp0_reg_data;
		end else begin
		  cp0_status <= cp0_status_i;
		end
	end
	
	always @ (*) begin
		if(rst == `RstEnable) begin
			cp0_epc <= `ZeroWord;
		end else if((wb_cp0_reg_we == `WriteEnable) && 
								(wb_cp0_reg_write_addr == `CP0_REG_EPC ))begin
			cp0_epc <= wb_cp0_reg_data;
		end else begin
		  cp0_epc <= cp0_epc_i;
		end
	end

  always @ (*) begin
		if(rst == `RstEnable) begin
			cp0_cause <= `ZeroWord;
		end else if((wb_cp0_reg_we == `WriteEnable) && 
								(wb_cp0_reg_write_addr == `CP0_REG_CAUSE ))begin
			cp0_cause[9:8] <= wb_cp0_reg_data[9:8];
			cp0_cause[22] <= wb_cp0_reg_data[22];
			cp0_cause[23] <= wb_cp0_reg_data[23];
		end else begin
		  cp0_cause <= cp0_cause_i;
		end
	end

	always @ (*) begin
		if(rst == `RstEnable) begin
			excepttype_o <= `ZeroWord;
		end else begin
			excepttype_o <= `ZeroWord;
			
			if(current_inst_address_i != `ZeroWord) begin
				if(((cp0_cause[15:8] & (cp0_status[15:8])) != 8'h00) && (cp0_status[1] == 1'b0) && 
							(cp0_status[0] == 1'b1)) begin
					excepttype_o <= 32'h00000001;        //interrupt
				end else if(excepttype_i[8] == 1'b1) begin
			  	excepttype_o <= 32'h00000008;        //syscall
				end else if(excepttype_i[9] == 1'b1) begin
					excepttype_o <= 32'h0000000a;        //inst_invalid
				end else if(excepttype_i[10] ==1'b1) begin
					excepttype_o <= 32'h0000000d;        //trap
				end else if(excepttype_i[11] == 1'b1) begin  //ov
					excepttype_o <= 32'h0000000c;
				end else if(excepttype_i[12] == 1'b1) begin  //·µ»ØÖ¸Áî
					excepttype_o <= 32'h0000000e;
				end
			end
				
		end
	end			

endmodule
